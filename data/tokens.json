{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "meta": {
    "name": "ACKO foundations (seed)",
    "description": "Normative values documented on the site. Ship product tokens in sync with /develop."
  },
  "color": {
    "core": {
      "purple-600": "#6841E6",
      "purple-100": "#EAEAFD",
      "purple-50": "#F5F3FF"
    },
    "neutral": {
      "gray-800": "#0A0A0A",
      "gray-550": "#333333",
      "gray-450": "#605F63",
      "gray-300": "#B7B7B8",
      "gray-200": "#E0E0E1",
      "gray-100": "#F5F5F5",
      "gray-50": "#FBFBFB",
      "cream": "#FAFAF8"
    },
    "semantic": {
      "auto": { "name": "Sunshade", "hex": "#F4A024" },
      "health": { "name": "Vivid Cerise", "hex": "#EC5FAB" },
      "life": { "name": "Picton Blue", "hex": "#1EB7E7" },
      "travel": { "name": "Leafy Green", "hex": "#55B94D" }
    },
    "accent": {
      "orange-600": "#EB740A",
      "green-600": "#16A34A"
    },
    "distributionBand": {
      "background": "40–60%",
      "headlineAccentCategory": "20%",
      "body": "10%",
      "cta": "10%"
    }
  },
  "typography": {
    "brandMarketing": "Gotham",
    "productDigital": "Euclid Circular B",
    "note": "Same hierarchy logic across contexts."
  },
  "logo": {
    "variations": [
      "Stacked / horizontal × with tagline / without tagline (four total)"
    ],
    "minimumDigitalPx": {
      "horizontal": 150,
      "vertical": 75
    }
  },
  "iconography": {
    "benchmark": "Hugeicons Stroke Rounded",
    "strokePx": 1.5,
    "default": "monochrome",
    "featured": "duotone"
  }
}
